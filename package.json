{
  "name": "tokenizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "test:visual": "node scripts/visual-validation.mjs",
    "typecheck": "tsc -b --pretty false",
    "design:lint": "designmd lint DESIGN.md",
    "design:fixtures": "node scripts/generate-design-fixture.mjs",
    "design:visual-diff": "node scripts/visual-diff-target.mjs"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@google/design.md": "^0.2.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "latest",
    "vitest": "latest"
  }
}
